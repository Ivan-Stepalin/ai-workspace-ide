# Порт бэкенда (HTTP + WebSocket)
PORT=3001

# Где хранить данные приложения. По умолчанию ./data рядом с процессом,
# внутри создаются projects/ и workspace.db.
# DATA_DIR=/abs/path/to/data

# Либо переопределить точечно (приоритетнее DATA_DIR):
# PROJECTS_DIR=/abs/path/projects
# DB_PATH=/abs/path/workspace.db

# ── Авторизация ──
# Секрет для подписи сессионного токена (httpOnly-cookie). В проде задать обязательно,
# иначе используется небезопасный дефолт. Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=замени-на-случайную-строку
# Первый пользователь (сидируется при старте, если такого нет): "логин:пароль" или "логин:пароль:роль".
# Роли: coder | analyst | tester | tourist (по умолчанию coder). Без этого войти будет некем.
# BOOTSTRAP_ADMIN=admin:пароль:coder
# Флаг Secure на cookie (для https):
# AUTH_COOKIE_SECURE=1

# ── Ретенция истории чатов (мс) ──
# Окно хранения (дефолт 7 дней) и период фоновой чистки (дефолт 1 час):
# CHAT_RETENTION_MS=604800000
# CHAT_RETENTION_SWEEP_MS=3600000

# Telegram-бот (опционально). Если задан токен от @BotFather — при старте бэкенда
# поднимается бот (long polling), дающий доступ к тем же агентам из Telegram.
# Без токена бот просто не запускается.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Разрешённые chat_id (через запятую). Только они могут управлять агентами.
# Если не задано — бот отвечает каждому его chat_id, но запросы к агентам не выполняет.
# Чтобы узнать свой id — напиши боту любое сообщение, он его пришлёт.
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
