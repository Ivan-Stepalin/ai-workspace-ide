# Зависимости и сборка
node_modules/
dist/
dist-ssr/
dev-dist/
*.tsbuildinfo

# Локальные настройки окружения (секреты/пути конкретной машины)
.env
.env.local
*.local

# Локальные TLS-сертификаты (mkcert) — содержат приватный ключ
certs/
*.pem

# Данные приложения (проекты пользователя и БД)
data/
*.db

# E2E (Playwright): артефакты и скриншоты
test-results/
playwright-report/
e2e/__screens__/

# Логи и системное
*.log
npm-debug.log*
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
